# وحدة مراقبة المبيعات السيارة - بروتوكول 1121
class SovereignMobileUnit:
    def __init__(self, unit_id, route):
        self.unit_id = unit_id
        self.route = route
        self.daily_sales = 0

    def record_sale(self, amount):
        self.daily_sales += amount
        print(f"الوحدة {self.unit_id} على طريق {self.route}: تم تسجيل بيع بقيمة {amount} MAD")

# توزيع الأسطول (4 اتجاه سبتة / 4 اتجاه واد لو)
fleet_north = [SovereignMobileUnit(i, "Sebta") for i in range(1, 5)]
