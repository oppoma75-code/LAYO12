            asset_value = asset.get('estimated_value', 100000)
            generated_value = asset_value * liquidity_weight
            
            total_liquidity_generated += generated_value
            
            # توليد ختم توثيق المعاملة (Liquidity Event Hash)
            event_hash = hashlib.sha256(f"{asset['hash']}-{generated_value}-{time.time()}".encode()).hexdigest()[:12].upper()
            
