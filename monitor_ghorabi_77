        print(f"الحالة: نشط | بروتوكول الربط: {self.protocol_code}")
        
        total_liquidity_generated = 0
        
        for asset in asset_data:
            # إدغام المنطق السيادي: القيمة الأساسية (1) + التوثيق الرقمي (1) = 12 وحدة سيولة
